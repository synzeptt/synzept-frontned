# Backend (FastAPI)
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://synzept:synzept@localhost:5432/synzept
JWT_SECRET_KEY=dev-only-change-me
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PASSWORD_RESET_EXPIRE_MINUTES=60
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=support@synzept.com
SMTP_USE_TLS=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=45
LLM_STREAM_START_TIMEOUT_SECONDS=12
RATE_LIMIT_PER_MINUTE=120
REQUEST_MAX_BODY_BYTES=1000000
SLOW_REQUEST_MS=1500
SLOW_OPERATION_MS=1000
LOG_JSON=false

# Frontend (Next.js on Vercel)
NEXT_PUBLIC_API_URL=http://20.244.28.232:8000

# Google Sign-In (optional) - same OAuth client ID as backend GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
