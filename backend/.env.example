ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false
CORS_ORIGINS=http://localhost:3000,https://app.synzept.com

# PostgreSQL (Supabase or Neon) — single source of truth
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Optional: Redis for durable background jobs (Dramatiq worker)
# Leave empty to use in-process asyncio jobs (fine for local dev)
REDIS_URL=

# Google Sign-In (optional) — OAuth 2.0 client ID from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=https://app.synzept.com
PASSWORD_RESET_EXPIRE_MINUTES=60

# SMTP for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=support@synzept.com
SMTP_USE_TLS=true

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

LLM_MAX_RETRIES=3
RATE_LIMIT_PER_MINUTE=120

# Supabase Storage (optional)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=synzept
